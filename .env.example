# Database Configuration
DATABASE_URL=ecto://postgres:postgres@localhost/vial_dev

# Phoenix Configuration
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret

# LLM Provider API Keys (optional - Ollama works locally without keys)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama Configuration (local LLM, no API key needed)
# Ollama runs locally on http://localhost:11434 by default
# Install from https://ollama.ai
