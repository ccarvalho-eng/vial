<Layouts.app flash={@flash} current_path={@current_path}>
  <div style="max-width: 800px; margin: 0 auto;">
    <h1>{@suite.name}</h1>
    <p style="margin-bottom: 24px; color: var(--text-secondary);">Prompt: {@prompt.name}</p>

    <%= if @prompt.versions != [] do %>
      <div style="margin-bottom: 32px;">
        <h2>Prompt Template</h2>
        <pre style="background-color: var(--bg-tertiary); border: 1px solid var(--border); padding: 12px; border-radius: 4px; font-size: 13px; line-height: 1.5; overflow-x: auto; margin: 0; white-space: pre-wrap; word-wrap: break-word; color: var(--text-secondary);"><%= List.first(@prompt.versions).template %></pre>
      </div>
    <% end %>

    <div style="margin-bottom: 32px;">
      <h2>Test Cases</h2>
      <div id="test-cases" style="display: flex; flex-direction: column; gap: 16px;">
        <%= for test_case <- @suite.test_cases do %>
          <div class="aludel-card">
            <h4>Variables:</h4>
            <pre style="background-color: var(--bg-tertiary); padding: 12px; border-radius: 6px; margin: 8px 0; font-size: 13px; overflow-x: auto;">{inspect(test_case.variable_values)}</pre>
            <h4>Assertions:</h4>
            <pre style="background-color: var(--bg-tertiary); padding: 12px; border-radius: 6px; margin: 8px 0; font-size: 13px; overflow-x: auto;">{inspect(test_case.assertions)}</pre>
          </div>
        <% end %>
      </div>
    </div>

    <div style="margin-bottom: 32px;">
      <h2>Run Suite</h2>
      <div class="aludel-card">
        <form phx-submit="run_suite" style="display: flex; flex-direction: column; gap: 16px;">
          <div>
            <label>Prompt Version</label>
            <select
              phx-change="select_version"
              name="version_id"
              required
              disabled={@running}
            >
              <%= for version <- @prompt.versions do %>
                <option value={version.id} selected={version.id == @selected_version_id}>
                  v{version.version}
                </option>
              <% end %>
            </select>
          </div>

          <div>
            <label>Provider</label>
            <select
              phx-change="select_provider"
              name="provider_id"
              required
              disabled={@running}
            >
              <%= for provider <- @providers do %>
                <option value={provider.id} selected={provider.id == @selected_provider_id}>
                  {provider.name}
                </option>
              <% end %>
            </select>
          </div>

          <button
            id="run-suite-btn"
            type="submit"
            class="button-primary"
            disabled={@running}
            style={"display: flex; align-items: center; gap: 8px; justify-content: center; #{if @running, do: "opacity: 0.6; cursor: not-allowed;", else: ""}"}
          >
            <%= if @running do %>
              <span style="display: inline-block; width: 14px; height: 14px; border: 2px solid currentColor; border-top-color: transparent; border-radius: 50%; animation: spin 0.6s linear infinite;">
              </span>
              Running...
            <% else %>
              Run Suite
            <% end %>
          </button>

          <%= if @running do %>
            <div style="padding: 12px; background-color: var(--bg-tertiary); border-radius: 6px; text-align: center; color: var(--text-secondary); font-size: 14px;">
              <div style="margin-bottom: 8px;">
                Executing test cases against the LLM...
              </div>
              <div style="font-size: 12px;">
                This may take a few moments depending on the number of test cases.
              </div>
            </div>
          <% end %>
        </form>
      </div>
    </div>

    <%= if @suite_runs != [] do %>
      <div style="margin-bottom: 32px;">
        <h2>Results</h2>
        <div style="display: flex; flex-direction: column; gap: 16px;">
          <%= for suite_run <- @suite_runs do %>
            <div class="aludel-card">
              <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 12px;">
                <div>
                  <div style="font-weight: 600; margin-bottom: 4px;">
                    v{suite_run.prompt_version.version} @ {suite_run.provider.name}
                  </div>
                  <div style="color: var(--text-secondary); font-size: 13px;">
                    {relative_time(suite_run.inserted_at)}
                  </div>
                </div>
                <div style="text-align: right;">
                  <div style="color: var(--text-secondary); font-size: 13px; margin-bottom: 4px;">
                    Passed: {suite_run.passed} | Failed: {suite_run.failed}
                  </div>
                  <div style="font-size: 12px; color: var(--text-muted);">
                    {suite_run.passed + suite_run.failed} test cases
                  </div>
                </div>
              </div>
              <div style="background-color: var(--bg-tertiary); padding: 16px; border-radius: 6px;">
                <%= for result <- suite_run.results do %>
                  <div style={"margin-bottom: 8px; padding: 12px; border-radius: 6px; background-color: #{if result["passed"], do: "rgba(16, 185, 129, 0.1)", else: "rgba(248, 81, 73, 0.1)"}; border: 1px solid #{if result["passed"], do: "#10b981", else: "#f85149"}"}>
                    <span style={"font-weight: 500; color: #{if result["passed"], do: "#10b981", else: "#f85149"}"}>
                      {if result["passed"], do: "✓", else: "✗"}
                    </span>
                    <pre style="font-size: 13px; margin-top: 4px; white-space: pre-wrap;">{result["output"]}</pre>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</Layouts.app>
