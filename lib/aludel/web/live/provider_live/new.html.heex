<Layouts.app flash={@flash} current_path={@current_path}>
  <div style="max-width: 800px; margin: 0 auto;">
    <h1>{if @live_action == :new, do: "New Provider", else: "Edit Provider"}</h1>

    <.form
      for={@form}
      id="provider-form"
      phx-change="validate"
      phx-submit="save"
      style="margin-top: 24px;"
    >
      <div class="aludel-card">
        <div style="margin-bottom: 16px;">
          <.input
            field={@form[:name]}
            type="text"
            label="Name"
            required
            placeholder="My OpenAI Provider"
          />
        </div>

        <div style="margin-bottom: 16px;">
          <.input
            field={@form[:provider]}
            type="select"
            label="Provider Type"
            required
            prompt="Select a provider type"
            options={[{"OpenAI", "openai"}, {"Anthropic", "anthropic"}, {"Ollama", "ollama"}]}
          />
        </div>

        <div style="margin-bottom: 16px;">
          <input type="hidden" name={@form[:model].name} value={@form[:model].value || ""} />
          <.input
            field={@form[:model_selection]}
            type="select"
            label="Model"
            required
            prompt="Select a model"
            options={@model_options}
          />
          <div style="font-size: 12px; color: var(--text-secondary); margin-top: 4px;">
            Active and deprecated models are grouped. Choose custom to enter a model name manually.
          </div>
        </div>

        <%= if @form[:model_selection].value == "custom" do %>
          <div style="margin-bottom: 16px;">
            <.input
              field={@form[:model_custom]}
              type="text"
              label="Custom model name"
              placeholder="my-model-name"
              required
            />
          </div>
        <% end %>

        <div>
          <div class="fieldset mb-2">
            <label>
              <span class="label mb-1">Configuration (JSON)</span>
              <textarea
                id={@form[:config].id}
                name={@form[:config].name}
                rows="6"
                placeholder='{"temperature": 0.7, "max_tokens": 1000}'
                class="w-full textarea font-mono text-[13px]"
              >{@config_json}</textarea>
            </label>
          </div>
          <div style="font-size: 12px; color: var(--text-secondary); margin-top: 4px;">
            Optional: Model parameters as JSON (temperature, max_tokens, etc.). API keys are set via environment variables.
          </div>
        </div>

        <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border);">
          <.link navigate={aludel_path("providers")} class="button-secondary">
            Cancel
          </.link>
          <button type="submit" class="button-primary">
            {if @live_action == :new, do: "Create Provider", else: "Update Provider"}
          </button>
        </div>
      </div>
    </.form>
  </div>
</Layouts.app>
