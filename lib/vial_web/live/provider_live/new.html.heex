<Layouts.app flash={@flash} current_path={@current_path}>
  <div style="max-width: 800px; margin: 0 auto;">
    <h1>{if @live_action == :new, do: "New Provider", else: "Edit Provider"}</h1>

    <.form for={@form} phx-submit="save" style="margin-top: 24px;">
      <div class="vial-card">
        <div style="margin-bottom: 16px;">
          <label for="provider_name">Name</label>
          <.input field={@form[:name]} type="text" required placeholder="My OpenAI Provider" />
        </div>

        <div style="margin-bottom: 16px;">
          <label for="provider_provider">Provider Type</label>
          <select name="provider[provider]" id="provider_provider" required>
            <option value="">Select a provider type</option>
            <option value="openai" selected={@form[:provider].value == :openai}>OpenAI</option>
            <option value="anthropic" selected={@form[:provider].value == :anthropic}>
              Anthropic
            </option>
            <option value="ollama" selected={@form[:provider].value == :ollama}>Ollama</option>
          </select>
        </div>

        <div style="margin-bottom: 16px;">
          <label for="provider_model">Model</label>
          <.input
            field={@form[:model]}
            type="text"
            required
            placeholder="gpt-4o, claude-3-5-sonnet-20241022, llama2, etc."
          />
          <div style="font-size: 12px; color: var(--text-secondary); margin-top: 4px;">
            Enter the model identifier (e.g., gpt-4o, claude-3-5-sonnet-20241022)
          </div>
        </div>

        <div style="margin-bottom: 16px;">
          <label for="provider_config">Configuration (JSON)</label>
          <textarea
            name="provider[config]"
            id="provider_config"
            rows="6"
            placeholder='{"temperature": 0.7, "max_tokens": 1000}'
            style="font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', Consolas, 'Courier New', monospace; font-size: 13px;"
          ><%= if @provider.config && map_size(@provider.config) > 0, do: Jason.encode!(@provider.config, pretty: true), else: "" %></textarea>
          <div style="font-size: 12px; color: var(--text-secondary); margin-top: 4px;">
            Optional: Model parameters as JSON (temperature, max_tokens, etc.). API keys are set via environment variables.
          </div>
        </div>
      </div>

      <div style="display: flex; gap: 12px; margin-top: 20px;">
        <button type="submit" class="button-primary">
          {if @live_action == :new, do: "Create Provider", else: "Update Provider"}
        </button>
        <.link navigate={~p"/providers"} class="button-secondary">
          Cancel
        </.link>
      </div>
    </.form>
  </div>
</Layouts.app>
